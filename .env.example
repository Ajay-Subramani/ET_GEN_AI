# VERCEL DEPLOYMENT CONFIGURATION
# Copy this file to .env.local for local development, or add these to your Vercel Project Settings.

# SUPABASE AUTH (Required for frontend session management)
# Find these in your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# BACKEND API CONNECTION (Required for frontend to reach the FastAPI agent)
# If hosting the backend on Render/Fly.io/AWS, place the public URL here.
# Default (if omitted) is http://127.0.0.1:8000 for local development.
AI_INVESTOR_API_BASE_URL="https://your-fastapi-backend-url.com"

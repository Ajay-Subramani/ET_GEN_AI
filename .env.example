# Local development configuration
# Copy this file to `.env.local` (do not commit `.env.local`).

# SUPABASE AUTH (Required for frontend session management)
# Find these in your Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# MARKET DATA (Required for live candles)
# Get an API key from https://twelvedata.com
TWELVEDATA_API_KEY="your-twelvedata-api-key"

# OPTIONAL: Ollama settings (only needed if you wire LLM steps later)
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL="deepseek-v3.2:cloud"
